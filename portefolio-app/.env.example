# Chave da API do Resend (https://resend.com) — obrigatória para o form de contacto funcionar.
# Sem ela, o /api/contact devolve 503 e o form mostra o fallback de email/WhatsApp.
RESEND_API_KEY=

# Remetente dos emails. Opcional — por omissão usa "James Steven <onboarding@resend.dev>".
# Com domínio próprio verificado no Resend: "James Steven <contacto@teudominio.pt>"
CONTACT_FROM_EMAIL=

# Destinatário das mensagens do form. Opcional — por omissão usa o CONTACT_EMAIL de src/lib/site.ts.
CONTACT_TO_EMAIL=

# URL pública do site (canonical, OG, sitemap). Definir no Netlify quando houver domínio próprio.
NEXT_PUBLIC_SITE_URL=https://james-steven-portefolio.netlify.app

# Domínio configurado no Plausible Analytics. Opcional — sem ele, o Analytics não carrega.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
